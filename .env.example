# 数据库路径（默认：data/sequoia_v2.db）
DB_PATH=data/sequoia_v2.db

# 数据起始日期（默认：2024-01-01）
START_DATE=2024-01-01

# WxPusher 配置
WXPUSHER_TOKEN=your_wxpusher_app_token
WXPUSHER_TOPIC_IDS=["39277"]

# DeepSeek LLM 配置（可选，用于AI多维度选股分析）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# 知兔 API Token（可选，用于个股实时行情含PE/PB/市值/60日涨幅）
# 申请地址：https://www.zhituapi.com/gettoken.html
ZHITU_TOKEN=your_zhitu_api_token_here
